<?xml version="1.0" encoding="utf-8"?>

<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:mp="http://schemas.microsoft.com/appx/2014/phone/manifest"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  xmlns:com="http://schemas.microsoft.com/appx/manifest/com/windows10"
  xmlns:desktop4="http://schemas.microsoft.com/appx/manifest/desktop/windows10/4"
  xmlns:desktop5="http://schemas.microsoft.com/appx/manifest/desktop/windows10/5"
  xmlns:desktop10="http://schemas.microsoft.com/appx/manifest/desktop/windows10/10"
  IgnorableNamespaces="uap uap3 rescap com desktop4 desktop5 desktop10">

  <Identity
    Name="PavloRybchenko.Pakko"
    Publisher="CN=EF3EC84C-8287-4FC3-BB4F-FCCEBA116BCE"
    Version="1.2.0.34" />

  <mp:PhoneIdentity PhoneProductId="c0456ca0-e25b-4778-95a2-045a49e4ab06" PhonePublisherId="00000000-0000-0000-0000-000000000000"/>

  <Properties>
    <DisplayName>Pakko</DisplayName>
    <PublisherDisplayName>Pavlo Rybchenko</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Universal" MinVersion="10.0.19041.0" MaxVersionTested="10.0.22621.0" />
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.19041.0" MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="x-generate"/>
  </Resources>

  <Applications>
    <Application Id="App"
      Executable="$targetnametoken$.exe"
      EntryPoint="$targetentrypoint$">
      <uap:VisualElements
        DisplayName="Pakko"
        Description="Modern ZIP archiver for Windows"
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png">
        <uap:DefaultTile Wide310x150Logo="Assets\Wide310x150Logo.png" />
        <uap:SplashScreen Image="Assets\SplashScreen.png" />
      </uap:VisualElements>
      <Extensions>
        <uap:Extension Category="windows.fileTypeAssociation">
          <uap:FileTypeAssociation Name="zipfile">
            <uap:SupportedFileTypes>
              <uap:FileType>.zip</uap:FileType>
            </uap:SupportedFileTypes>
            <uap:DisplayName>Pakko ZIP Archive</uap:DisplayName>
            <uap:Logo>Assets\Square44x44Logo.png</uap:Logo>
          </uap:FileTypeAssociation>
        </uap:Extension>
        <!-- T-F100: extensions Archiver.Core actually routes to ITarService/tar.exe today.
             Reuses ShellExtUtils.cpp's kSupportedNonZipArchiveExtensions list (already the
             project's single source of truth for this set, kept in sync with
             MainViewModel.cs's _extractableTypes) rather than NanaZip's much larger ~60-extension
             list, since Pakko doesn't support most of those. Runtime capability gaps (older
             Windows without a capable tar.exe) still surface ArchiveListingRouter/
             ExtractionRouter's existing "not supported" error instead of a silent failure. -->
        <uap:Extension Category="windows.fileTypeAssociation">
          <uap:FileTypeAssociation Name="archivefile">
            <uap:SupportedFileTypes>
              <uap:FileType>.rar</uap:FileType>
              <uap:FileType>.7z</uap:FileType>
              <uap:FileType>.tar</uap:FileType>
              <uap:FileType>.gz</uap:FileType>
              <uap:FileType>.tgz</uap:FileType>
              <uap:FileType>.bz2</uap:FileType>
              <uap:FileType>.tbz2</uap:FileType>
              <uap:FileType>.xz</uap:FileType>
              <uap:FileType>.txz</uap:FileType>
              <uap:FileType>.zst</uap:FileType>
              <uap:FileType>.tzst</uap:FileType>
              <uap:FileType>.lzma</uap:FileType>
            </uap:SupportedFileTypes>
            <uap:DisplayName>Pakko Archive</uap:DisplayName>
            <uap:Logo>Assets\Square44x44Logo.png</uap:Logo>
          </uap:FileTypeAssociation>
        </uap:Extension>
        <uap3:Extension Category="windows.protocol">
          <uap3:Protocol Name="pakko" />
        </uap3:Extension>
        <!--
          T-F61: IExplorerCommand shell extension (Archiver.ShellExtension.dll), registered
          as a SurrogateServer — same schema as NanaZip's shipped manifest (verified against
          github.com/M2Team/NanaZip). Runs the DLL inside an isolated dllhost.exe surrogate,
          so a crash in the extension does not bring down explorer.exe.
          desktop4:FileExplorerContextMenus wires the classic context menu.
          Type="*" — all files, including .zip (no duplicate .zip entry needed)
        -->
        <com:Extension Category="windows.comServer">
          <com:ComServer>
            <com:SurrogateServer DisplayName="Pakko Shell Extension">
              <com:Class Id="1EABC7CE-20A4-48EE-A99F-43D4E0F58D6A"
                         Path="Archiver.ShellExtension.dll"
                         ThreadingModel="STA" />
            </com:SurrogateServer>
          </com:ComServer>
        </com:Extension>
        <desktop4:Extension Category="windows.fileExplorerContextMenus">
          <desktop4:FileExplorerContextMenus>
            <desktop4:ItemType Type="*">
              <desktop4:Verb Id="0000PakkoShellExtension"
                             Clsid="1EABC7CE-20A4-48EE-A99F-43D4E0F58D6A" />
            </desktop4:ItemType>
            <desktop5:ItemType Type="Directory">
              <desktop5:Verb Id="0000PakkoShellExtension"
                             Clsid="1EABC7CE-20A4-48EE-A99F-43D4E0F58D6A" />
            </desktop5:ItemType>
            <!-- T-F99: drive-root selections (e.g. right-clicking C:\ in Explorer's tree or
                 "This PC") are a distinct ItemType from Directory - without this entry Explorer
                 never queries PakkoRootCommand for a drive root at all. Verified against
                 NanaZip's shipped manifest, which registers the same Type="Drive" entry. -->
            <desktop10:ItemType Type="Drive">
              <desktop10:Verb Id="0000PakkoShellExtension"
                              Clsid="1EABC7CE-20A4-48EE-A99F-43D4E0F58D6A" />
            </desktop10:ItemType>
          </desktop4:FileExplorerContextMenus>
        </desktop4:Extension>
      </Extensions>
    </Application>

    <!--
      Archiver.Shell.exe must be declared as its own <Application> — Windows blocks
      CreateProcess of any EXE inside an installed package's WindowsApps folder unless it is
      a declared Application entry point (confirmed via microsoft/WindowsAppSDK#4651;
      verified empirically: CreateProcess against the undeclared Archiver.Shell.exe from an
      external process returned ERROR_ACCESS_DENIED). This blocked the shell extension's
      Invoke() from ever launching Archiver.Shell.exe, so the context menu appeared but its
      commands silently did nothing.
      AppListEntry="none" hides it from the Start menu / app list — it is never
      user-launched directly.
    -->
    <Application Id="ShellHelper"
      Executable="Archiver.Shell.exe"
      EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="Pakko Shell Helper"
        Description="Pakko context-menu command handler"
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png"
        AppListEntry="none">
      </uap:VisualElements>
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
