<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Archiver.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Archiver.App"
    xmlns:viewmodels="using:Archiver.App.ViewModels"
    xmlns:models="using:Archiver.App.Models"
    xmlns:appcore="using:Archiver.App.Core"
    xmlns:tb="using:H.NotifyIcon"
    Title="Archiver">

    <!-- T-F106: Row 1 (the file table) got MinHeight="200" on its RowDefinition itself, not just
         on the ListView child inside it — a child's own MinHeight does not force a Grid's Star
         row to grow past what the row-sizing algorithm allocates. Root cause of the "blank rows"
         investigation (see DECISIONS.md): with a fixed 650px-tall window, the combined Auto-sized
         rows below (Archive Options' 4 rows, Shared Options, action buttons, status bar) could
         demand more height than the window had, collapsing this Star row to 0 — every ListView
         item then measured/arranged within zero available height, reporting (0,0,0)
         UI-Automation bounds regardless of population timing, data model, or XAML structure
         (all five previously-tried, ultimately-irrelevant hypotheses). Not a WinUI rendering bug
         at all — a plain missing minimum-size guarantee, which was T-F106 Sub-scope B all along. -->
    <Grid x:Name="RootGrid" Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="140"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tray icon -->
        <tb:TaskbarIcon
            x:Name="TrayIcon"
            LeftClickCommand="{x:Bind TrayLeftClickCommand}"
            ToolTipText="Pakko"
            IconSource="Assets/Square44x44Logo.ico">
            <tb:TaskbarIcon.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem x:Uid="TrayOpenMenuItem" Command="{x:Bind TrayOpenCommand}"/>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem x:Uid="TrayAboutMenuItem" Command="{x:Bind TrayAboutCommand}"/>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem x:Uid="TrayExitMenuItem" Command="{x:Bind TrayExitCommand}"/>
                </MenuFlyout>
            </tb:TaskbarIcon.ContextFlyout>
        </tb:TaskbarIcon>

        <!-- Row 0: Add Files / Add Folder / Hash / About Buttons -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,*,Auto,Auto" MinHeight="40"
              Visibility="{x:Bind ViewModel.IsPendingListVisibility, Mode=OneWay}">
            <Button
                Grid.Column="0"
                x:Uid="AddFilesButton"
                Command="{x:Bind ViewModel.BrowseFilesCommand, Mode=OneWay}"/>
            <Button
                Grid.Column="1"
                x:Uid="AddFolderButton"
                Margin="8,0,0,0"
                Command="{x:Bind ViewModel.BrowseFolderCommand, Mode=OneWay}"/>
            <Button
                Grid.Column="3"
                x:Uid="HashButton"
                HorizontalAlignment="Right"
                Command="{x:Bind HashFilesCommand, Mode=OneTime}"/>
            <Button
                Grid.Column="4"
                x:Uid="AboutButton"
                Margin="8,0,0,0"
                HorizontalAlignment="Right"
                Command="{x:Bind TrayAboutCommand, Mode=OneTime}"/>
        </Grid>

        <!-- Row 0 (T-F05): Archive Browser Top Command Bar. The Info button that originally sat
             here was removed (design review 2026-07-13): its Name/Path/Type/Size/Compressed-size/
             Modified fields all now live directly on the entry table below (Row 1 browse). The
             Close button that replaced it was removed in the same follow-up round — the up-arrow
             now in front of the breadcrumb (Row 1 browse) doubles as the exit affordance (see
             MainViewModel.NavigateUpOrExitBrowser): only About remains here. -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" MinHeight="40"
              Visibility="{x:Bind ViewModel.IsBrowsingArchiveVisibility, Mode=OneWay}">
            <Button
                Grid.Column="1"
                x:Uid="AboutButton"
                HorizontalAlignment="Right"
                Command="{x:Bind TrayAboutCommand, Mode=OneTime}"/>
        </Grid>

        <!-- Row 1: File Table -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*"
              Visibility="{x:Bind ViewModel.IsPendingListVisibility, Mode=OneWay}">

            <!-- Header -->
            <Border
                Grid.Row="0"
                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*,80,100,90,140" Margin="12,0,12,0">
                    <Button Grid.Column="0" x:Uid="NameColumnHeader"
                            Command="{x:Bind ViewModel.SortByCommand, Mode=OneWay}"
                            CommandParameter="Name"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0"
                            Padding="0,6,0,6" FontWeight="SemiBold"/>
                    <Button Grid.Column="1" x:Uid="TypeColumnHeader"
                            Command="{x:Bind ViewModel.SortByCommand, Mode=OneWay}"
                            CommandParameter="Type"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0"
                            Padding="0,6,0,6" FontWeight="SemiBold"/>
                    <Button Grid.Column="2" x:Uid="SizeColumnHeader"
                            Command="{x:Bind ViewModel.SortByCommand, Mode=OneWay}"
                            CommandParameter="Size"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0"
                            Padding="0,6,0,6" FontWeight="SemiBold"/>
                    <Button Grid.Column="3" x:Uid="CrcColumnHeader"
                            Command="{x:Bind ViewModel.SortByCommand, Mode=OneWay}"
                            CommandParameter="Crc"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0"
                            Padding="0,6,0,6" FontWeight="SemiBold"/>
                    <Button Grid.Column="4" x:Uid="ModifiedColumnHeader"
                            Command="{x:Bind ViewModel.SortByCommand, Mode=OneWay}"
                            CommandParameter="Modified"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0"
                            Padding="0,6,0,6" FontWeight="SemiBold"/>
                </Grid>
            </Border>

            <!-- Body: ListView + empty-state hint overlay in the same cell -->
            <Grid Grid.Row="1">
                <ListView
                    x:Name="FileListView"
                    ItemsSource="{x:Bind ViewModel.FileItems, Mode=OneWay}"
                    SelectionMode="None"
                    MinHeight="80"
                    AllowDrop="True"
                    DragOver="FileList_DragOver"
                    Drop="FileList_Drop"
                    DoubleTapped="PendingList_DoubleTapped">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="12,4,12,4"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:FileItem">
                            <Grid ColumnDefinitions="*,80,100,90,140">
                                <Grid.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem x:Uid="RemoveMenuItem" Click="RemoveItem_Click"/>
                                    </MenuFlyout>
                                </Grid.ContextFlyout>
                                <TextBlock
                                    Grid.Column="0"
                                    Text="{x:Bind Name}"
                                    TextTrimming="CharacterEllipsis"
                                    ToolTipService.ToolTip="{x:Bind FullPath}"/>
                                <TextBlock
                                    Grid.Column="1"
                                    Text="{x:Bind Type}"
                                    TextTrimming="CharacterEllipsis"
                                    Opacity="0.7"/>
                                <TextBlock
                                    Grid.Column="2"
                                    Text="{x:Bind Size, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis"
                                    Opacity="0.7"/>
                                <TextBlock
                                    Grid.Column="3"
                                    Text="{x:Bind Crc32Display, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis"
                                    Opacity="0.7"/>
                                <TextBlock
                                    Grid.Column="4"
                                    Text="{x:Bind ModifiedDisplay}"
                                    TextTrimming="CharacterEllipsis"
                                    Opacity="0.7"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Empty-state hint overlay -->
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="2"
                    IsHitTestVisible="False"
                    Visibility="{x:Bind ViewModel.IsFileListEmptyVisibility, Mode=OneWay}">
                    <FontIcon Glyph="&#xE8B7;" FontSize="20" Opacity="0.6"/>
                    <TextBlock
                        x:Uid="DropZoneHint"
                        HorizontalAlignment="Center"
                        Opacity="0.6"/>
                    <TextBlock
                        x:Uid="DropZoneModeHint"
                        HorizontalAlignment="Center"
                        Opacity="0.6"
                        Style="{StaticResource CaptionTextBlockStyle}"/>
                </StackPanel>
            </Grid>

        </Grid>

        <!-- Row 1 (T-F05): Archive Browser -->
        <Grid Grid.Row="1" RowDefinitions="Auto,Auto,*"
              Visibility="{x:Bind ViewModel.IsBrowsingArchiveVisibility, Mode=OneWay}">

            <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,8">
                <!-- T-F107: up one archive folder level; at the archive root, keeps climbing into
                     real Windows folders (containing folder, drive root, "This PC" drives list) —
                     never exits the browser back to the pending list anymore. Disabled only at
                     "This PC" (MainViewModel.CanNavigateUp), mirroring the destination path row's
                     own drive-root disable pattern. See DECISIONS.md's T-F107 entry. -->
                <Button
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    Padding="8,4,8,4"
                    Command="{x:Bind ViewModel.NavigateUpCommand, Mode=OneWay}"
                    ToolTipService.ToolTip="Up">
                    <FontIcon Glyph="&#xE74A;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                </Button>
                <BreadcrumbBar
                    Grid.Column="1"
                    ItemsSource="{x:Bind ViewModel.BreadcrumbSegments, Mode=OneWay}"
                    ItemClicked="ArchiveBreadcrumb_ItemClicked"/>
            </Grid>

            <Border
                Grid.Row="1"
                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="Auto,*,100,100,90,140" Margin="12,0,12,0">
                    <TextBlock Grid.Column="1" x:Uid="BrowseNameColumnHeader" Padding="0,6,0,6" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="2" x:Uid="BrowseSizeColumnHeader" Padding="0,6,0,6" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="3" x:Uid="PackedColumnHeader" Padding="0,6,0,6" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="4" x:Uid="BrowseCrcColumnHeader" Padding="0,6,0,6" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="5" x:Uid="BrowseModifiedColumnHeader" Padding="0,6,0,6" FontWeight="SemiBold"/>
                </Grid>
            </Border>

            <ListView
                Grid.Row="2"
                x:Name="ArchiveBrowserListView"
                ItemsSource="{x:Bind ViewModel.CurrentFolderEntries, Mode=OneWay}"
                SelectionMode="Multiple"
                MinHeight="80"
                IsEnabled="{x:Bind ViewModel.IsNotBusy, Mode=OneWay}"
                SelectionChanged="ArchiveBrowserList_SelectionChanged"
                DoubleTapped="ArchiveBrowserList_DoubleTapped">
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel Orientation="Vertical" VirtualizationMode="Recycling"/>
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="12,4,12,4"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="appcore:ArchiveEntryViewModel">
                        <Grid ColumnDefinitions="Auto,*,100,100,90,140">
                            <FontIcon
                                Grid.Column="0"
                                Glyph="{x:Bind Icon}"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="14"
                                Margin="0,0,8,0"
                                Opacity="0.7"/>
                            <TextBlock
                                Grid.Column="1"
                                Text="{x:Bind Name}"
                                TextTrimming="CharacterEllipsis"
                                ToolTipService.ToolTip="{x:Bind FullPath}"/>
                            <TextBlock
                                Grid.Column="2"
                                Text="{x:Bind SizeDisplay}"
                                TextTrimming="CharacterEllipsis"
                                Opacity="0.7"/>
                            <TextBlock
                                Grid.Column="3"
                                Text="{x:Bind CompressedSizeDisplay}"
                                TextTrimming="CharacterEllipsis"
                                Opacity="0.7"/>
                            <TextBlock
                                Grid.Column="4"
                                Text="{x:Bind CrcDisplay}"
                                TextTrimming="CharacterEllipsis"
                                Opacity="0.7"/>
                            <TextBlock
                                Grid.Column="5"
                                Text="{x:Bind ModifiedDisplay}"
                                TextTrimming="CharacterEllipsis"
                                Opacity="0.7"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Row 2: Destination Path -->
        <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,*,Auto" MinHeight="40">
            <TextBlock
                x:Uid="DestinationLabel"
                Grid.Column="0"
                VerticalAlignment="Center"
                Margin="0,0,8,0"
                Style="{StaticResource CaptionTextBlockStyle}"/>
            <!-- Up to parent folder; disabled at a drive root (Path.GetDirectoryName returns
                 null there — see MainViewModel.CanNavigateDestinationUp). Added per user request
                 alongside the archive browser's own up/exit button. -->
            <Button
                Grid.Column="1"
                Margin="0,0,8,0"
                Padding="8,4,8,4"
                Command="{x:Bind ViewModel.NavigateDestinationUpCommand, Mode=OneWay}"
                ToolTipService.ToolTip="Up">
                <FontIcon Glyph="&#xE74A;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
            </Button>
            <TextBox
                Grid.Column="2"
                Text="{x:Bind ViewModel.DestinationPath, Mode=OneWay}"
                IsReadOnly="True"
                VerticalAlignment="Center"/>
            <Button
                Grid.Column="3"
                Content="..."
                Margin="8,0,0,0"
                Command="{x:Bind ViewModel.BrowseDestinationCommand, Mode=OneWay}"
                IsEnabled="{x:Bind ViewModel.IsNotBusy, Mode=OneWay}"/>
        </Grid>

        <!-- Row 3: Action Buttons -->
        <Grid Grid.Row="3" ColumnDefinitions="*,*,Auto" MinHeight="40"
              Visibility="{x:Bind ViewModel.IsPendingListVisibility, Mode=OneWay}">

            <Button
                Grid.Column="0"
                Content="{x:Bind ViewModel.ArchiveButtonText, Mode=OneWay}"
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.ArchiveCommand, Mode=OneWay}"
                Style="{x:Bind ViewModel.ArchiveButtonStyle, Mode=OneWay}"/>

            <Button
                Grid.Column="1"
                Content="{x:Bind ViewModel.ExtractButtonText, Mode=OneWay}"
                Margin="8,0,0,0"
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.ExtractCommand, Mode=OneWay}"
                Style="{x:Bind ViewModel.ExtractButtonStyle, Mode=OneWay}"/>

            <Button
                x:Uid="ClearButton"
                Grid.Column="2"
                Margin="8,0,0,0"
                Command="{x:Bind ViewModel.ClearCommand, Mode=OneWay}"/>
        </Grid>

        <!-- Row 3 (T-F05): Archive Browser Action Buttons — Info/Close moved to the Row 0
             command bar above (design review 2026-07-13); these two stay anchored here, next to
             the destination path/conflict-behavior options (Row 2/Row 6) they actually consume. -->
        <Grid Grid.Row="3" ColumnDefinitions="*,*" MinHeight="40"
              Visibility="{x:Bind ViewModel.IsBrowsingArchiveVisibility, Mode=OneWay}">

            <Button
                Grid.Column="0"
                x:Uid="ExtractSelectedButton"
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.ExtractSelectedFromBrowserCommand, Mode=OneWay}"/>

            <Button
                Grid.Column="1"
                x:Uid="ExtractAllButton"
                Margin="8,0,0,0"
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.ExtractAllFromBrowserCommand, Mode=OneWay}"/>
        </Grid>

        <!-- Row 4: Operation Outcome Subtitle -->
        <TextBlock
            Grid.Row="4"
            Text="{x:Bind ViewModel.OperationOutcomeText, Mode=OneWay}"
            Visibility="{x:Bind ViewModel.OperationOutcomeVisibility, Mode=OneWay}"
            Style="{StaticResource CaptionTextBlockStyle}"/>

        <!-- Row 5: Archive Options (Mode + Name). A single Grid (not per-row StackPanels) so
             column 0's Auto width is computed once across all four rows, keeping every label's
             right edge aligned regardless of which locale's string is longest — WinUI has no
             WPF-style IsSharedSizeScope/SharedSizeGroup to do this across separate Grids, but
             Auto-column sizing already gives the same result within one Grid (T-F106-adjacent
             alignment fix, 2026-07-16: ModeLabel/ArchiveNameLabel previously used a hardcoded
             Width="46" tuned for English, which wrapped Ukrainian "Режим:" onto two lines). -->
        <Grid
            Grid.Row="5"
            RowSpacing="8"
            Visibility="{x:Bind ViewModel.ArchiveOptionsVisibility, Mode=OneWay}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" MinHeight="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto" MinHeight="40"/>
                <RowDefinition Height="Auto" MinHeight="40"/>
            </Grid.RowDefinitions>

            <TextBlock x:Uid="ModeLabel" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}"/>
            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="16" Margin="8,0,0,0">
                <RadioButton
                    x:Uid="OneArchiveRadio"
                    GroupName="ArchiveMode"
                    IsChecked="{x:Bind ViewModel.IsSingleArchive, Mode=TwoWay}"
                    IsEnabled="{x:Bind ViewModel.IsNotBusy, Mode=OneWay}"/>
                <RadioButton
                    x:Uid="SeparateArchivesRadio"
                    GroupName="ArchiveMode"
                    IsChecked="{x:Bind ViewModel.IsSeparateArchives, Mode=TwoWay}"
                    IsEnabled="{x:Bind ViewModel.IsNotBusy, Mode=OneWay}"/>
            </StackPanel>

            <TextBlock
                x:Uid="ArchiveNameLabel"
                Grid.Row="1"
                Grid.Column="0"
                VerticalAlignment="Center"
                Style="{StaticResource CaptionTextBlockStyle}"/>
            <TextBox
                x:Uid="ArchiveNameTextBox"
                Grid.Row="1"
                Grid.Column="1"
                Margin="8,0,0,0"
                Text="{x:Bind ViewModel.ArchiveName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                IsEnabled="{x:Bind ViewModel.IsArchiveNameAndNotBusy, Mode=OneWay}"/>

            <TextBlock x:Uid="FormatLabel" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}"/>
            <ComboBox Grid.Row="2" Grid.Column="1" Margin="8,0,0,0" HorizontalAlignment="Left" MinHeight="32" SelectedIndex="{x:Bind ViewModel.FormatIndex, Mode=TwoWay}"
                      IsEnabled="{x:Bind ViewModel.IsNotBusy, Mode=OneWay}">
                <ComboBoxItem x:Uid="FormatZipItem"/>
                <ComboBoxItem x:Uid="FormatTarItem" Visibility="{x:Bind ViewModel.TarFormatVisibility}"/>
                <ComboBoxItem x:Uid="FormatTarGzItem" Visibility="{x:Bind ViewModel.TarFormatVisibility}"/>
                <ComboBoxItem x:Uid="FormatTarBz2Item" Visibility="{x:Bind ViewModel.TarFormatVisibility}"/>
                <ComboBoxItem x:Uid="FormatTarXzItem" Visibility="{x:Bind ViewModel.TarFormatVisibility}"/>
                <ComboBoxItem x:Uid="FormatTarZstItem" Visibility="{x:Bind ViewModel.TarFormatVisibility}"/>
                <ComboBoxItem x:Uid="FormatTarLzmaItem" Visibility="{x:Bind ViewModel.TarFormatVisibility}"/>
            </ComboBox>

            <TextBlock x:Uid="CompressionLabel" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}"/>
            <ComboBox Grid.Row="3" Grid.Column="1" Margin="8,0,0,0" HorizontalAlignment="Left" MinHeight="32" SelectedIndex="{x:Bind ViewModel.CompressionLevelIndex, Mode=TwoWay}"
                      IsEnabled="{x:Bind ViewModel.IsCompressionLevelEnabled, Mode=OneWay}">
                <ComboBoxItem x:Uid="CompressionFastItem"/>
                <ComboBoxItem x:Uid="CompressionNormalItem"/>
                <ComboBoxItem x:Uid="CompressionBestItem"/>
                <ComboBoxItem x:Uid="CompressionNoneItem"/>
            </ComboBox>
        </Grid>

        <!-- Row 6: Shared Options + Post-Action Checkboxes -->
        <StackPanel Grid.Row="6" Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8" MinHeight="40">
                <TextBlock x:Uid="ConflictLabel" VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}"/>
                <ComboBox MinHeight="32" SelectedIndex="{x:Bind ViewModel.OnConflictIndex, Mode=TwoWay}"
                          IsEnabled="{x:Bind ViewModel.IsNotBusy, Mode=OneWay}">
                    <ComboBoxItem x:Uid="ConflictOverwriteItem"/>
                    <ComboBoxItem x:Uid="ConflictSkipItem"/>
                    <ComboBoxItem x:Uid="ConflictRenameItem"/>
                    <ComboBoxItem x:Uid="ConflictAskItem"/>
                </ComboBox>
            </StackPanel>
            <CheckBox
            x:Uid="OpenDestinationCheck"
            IsChecked="{x:Bind ViewModel.OpenDestinationFolder, Mode=TwoWay}"
            IsEnabled="{x:Bind ViewModel.IsNotBusy, Mode=OneWay}"/>
            <CheckBox
            x:Uid="DeleteAfterOperationCheck"
            IsChecked="{x:Bind ViewModel.DeleteAfterOperation, Mode=TwoWay}"
            IsEnabled="{x:Bind ViewModel.IsNotBusy, Mode=OneWay}"/>
        </StackPanel>

        <!-- Row 7: Status Bar -->
        <Grid Grid.Row="7" RowDefinitions="Auto,Auto" RowSpacing="4">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                <ProgressBar
                    Grid.Column="0"
                    Value="{x:Bind ViewModel.Progress, Mode=OneWay}"
                    Maximum="100"
                    IsIndeterminate="{x:Bind ViewModel.IsProgressIndeterminate, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.IsOperationRunningVisibility, Mode=OneWay}"/>
                <Button
                    x:Uid="CancelButton"
                    Grid.Column="1"
                    Margin="8,0,0,0"
                    Command="{x:Bind ViewModel.CancelCommand, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.IsOperationRunningVisibility, Mode=OneWay}"/>
            </Grid>
            <TextBlock
                Grid.Row="1"
                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                Opacity="0.7"
                FontSize="12"
                TextTrimming="CharacterEllipsis"/>
        </Grid>
    </Grid>
</Window>
