<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Archiver.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Archiver.App"
    xmlns:viewmodels="using:Archiver.App.ViewModels"
    xmlns:models="using:Archiver.App.Models"
    Title="Archiver">

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto,Auto,Auto,Auto" Padding="16" RowSpacing="12">

        <!-- Row 0: Drop Zone -->
        <Border
            Grid.Row="0"
            Height="120"
            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
            BorderThickness="2"
            CornerRadius="8"
            AllowDrop="True"
            DragOver="DropZone_DragOver"
            Drop="DropZone_Drop"
            DoubleTapped="DropZone_DoubleTapped"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                <FontIcon Glyph="&#xE8B7;" FontSize="28" Opacity="0.6"/>
                <TextBlock
                    Text="Drop files or folders here, or double-click to browse files"
                    HorizontalAlignment="Center"
                    Opacity="0.6"/>
            </StackPanel>
        </Border>

        <!-- Row 1: Add Files / Add Folder Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <Button
                Content="Add files"
                Command="{x:Bind ViewModel.BrowseFilesCommand, Mode=OneWay}"/>
            <Button
                Content="Add folder"
                Command="{x:Bind ViewModel.BrowseFolderCommand, Mode=OneWay}"/>
        </StackPanel>

        <!-- Row 2: File Table -->
        <Grid Grid.Row="2" RowDefinitions="Auto,*">

            <!-- Header -->
            <Border
                Grid.Row="0"
                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*,80,100,140" Margin="12,0,12,0">
                    <Button Grid.Column="0" Content="Name"
                            Command="{x:Bind ViewModel.SortByCommand, Mode=OneWay}"
                            CommandParameter="Name"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0"
                            Padding="0,6,0,6" FontWeight="SemiBold"/>
                    <Button Grid.Column="1" Content="Type"
                            Command="{x:Bind ViewModel.SortByCommand, Mode=OneWay}"
                            CommandParameter="Type"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0"
                            Padding="0,6,0,6" FontWeight="SemiBold"/>
                    <Button Grid.Column="2" Content="Size"
                            Command="{x:Bind ViewModel.SortByCommand, Mode=OneWay}"
                            CommandParameter="Size"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0"
                            Padding="0,6,0,6" FontWeight="SemiBold"/>
                    <Button Grid.Column="3" Content="Modified"
                            Command="{x:Bind ViewModel.SortByCommand, Mode=OneWay}"
                            CommandParameter="Modified"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0"
                            Padding="0,6,0,6" FontWeight="SemiBold"/>
                </Grid>
            </Border>

            <!-- Body -->
            <ListView
                Grid.Row="1"
                ItemsSource="{x:Bind ViewModel.FileItems, Mode=OneWay}"
                SelectionMode="None"
                MinHeight="80">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="12,4,12,4"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:FileItem">
                        <Grid ColumnDefinitions="*,80,100,140">
                            <Grid.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Remove" Click="RemoveItem_Click"/>
                                </MenuFlyout>
                            </Grid.ContextFlyout>
                            <TextBlock
                                Grid.Column="0"
                                Text="{x:Bind Name}"
                                TextTrimming="CharacterEllipsis"
                                ToolTipService.ToolTip="{x:Bind FullPath}"/>
                            <TextBlock
                                Grid.Column="1"
                                Text="{x:Bind Type}"
                                TextTrimming="CharacterEllipsis"
                                Opacity="0.7"/>
                            <TextBlock
                                Grid.Column="2"
                                Text="{x:Bind Size, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis"
                                Opacity="0.7"/>
                            <TextBlock
                                Grid.Column="3"
                                Text="{x:Bind ModifiedDisplay}"
                                TextTrimming="CharacterEllipsis"
                                Opacity="0.7"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </Grid>

        <!-- Row 3: Destination Path -->
        <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto">
            <TextBlock
                Grid.Column="0"
                Text="Destination:"
                VerticalAlignment="Center"
                Margin="0,0,8,0"/>
            <TextBox
                Grid.Column="1"
                Text="{x:Bind ViewModel.DestinationPath, Mode=OneWay}"
                IsReadOnly="True"
                VerticalAlignment="Center"/>
            <Button
                Grid.Column="2"
                Content="..."
                Margin="8,0,0,0"
                Command="{x:Bind ViewModel.BrowseDestinationCommand, Mode=OneWay}"/>
        </Grid>

        <!-- Row 4: Action Buttons -->
        <Grid Grid.Row="4" ColumnDefinitions="*,*,Auto">

            <Button
                Grid.Column="0"
                Content="Archive"
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.ArchiveCommand, Mode=OneWay}"
                Style="{StaticResource AccentButtonStyle}"/>

            <Button
                Grid.Column="1"
                Content="Extract"
                Margin="8,0,0,0"
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.ExtractCommand, Mode=OneWay}"/>

            <Button
                Grid.Column="2"
                Content="Clear"
                Margin="8,0,0,0"
                Command="{x:Bind ViewModel.ClearCommand, Mode=OneWay}"/>
        </Grid>

        <!-- Row 5: Archive Options (Mode + Name) -->
        <StackPanel Grid.Row="5" Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="Mode:" VerticalAlignment="Center" Width="46"/>
                <RadioButton
                    GroupName="ArchiveMode"
                    Content="One archive"
                    IsChecked="{x:Bind ViewModel.IsSingleArchive, Mode=TwoWay}"/>
                <RadioButton
                    GroupName="ArchiveMode"
                    Content="Separate archives"
                    IsChecked="{x:Bind ViewModel.IsSeparateArchives, Mode=TwoWay}"/>
            </StackPanel>
            <Grid ColumnDefinitions="Auto,*">
                <TextBlock
                    Grid.Column="0"
                    Text="Name:"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0"
                    Width="46"/>
                <TextBox
                    Grid.Column="1"
                    Text="{x:Bind ViewModel.ArchiveName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="Auto (based on first file/folder name)"
                    IsEnabled="{x:Bind ViewModel.IsArchiveNameEnabled, Mode=OneWay}"/>
            </Grid>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Compression:" VerticalAlignment="Center"/>
                <ComboBox SelectedIndex="{x:Bind ViewModel.CompressionLevelIndex, Mode=TwoWay}">
                    <ComboBoxItem Content="Fast"/>
                    <ComboBoxItem Content="Normal"/>
                    <ComboBoxItem Content="Best"/>
                    <ComboBoxItem Content="None"/>
                </ComboBox>
            </StackPanel>
        </StackPanel>

        <!-- Row 6: Shared Options + Post-Action Checkboxes -->
        <StackPanel Grid.Row="6" Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="If file exists:" VerticalAlignment="Center"/>
                <ComboBox SelectedIndex="{x:Bind ViewModel.OnConflictIndex, Mode=TwoWay}">
                    <ComboBoxItem Content="Overwrite"/>
                    <ComboBoxItem Content="Skip"/>
                    <ComboBoxItem Content="Rename (add number)"/>
                </ComboBox>
            </StackPanel>
            <CheckBox
                Content="Open destination folder after completion"
                IsChecked="{x:Bind ViewModel.OpenDestinationFolder, Mode=TwoWay}"/>
            <CheckBox
                Content="Delete source files after archiving"
                IsChecked="{x:Bind ViewModel.DeleteSourceFiles, Mode=TwoWay}"/>
            <CheckBox
                Content="Delete archive after extraction"
                IsChecked="{x:Bind ViewModel.DeleteArchiveAfterExtraction, Mode=TwoWay}"/>
        </StackPanel>

        <!-- Row 7: Status Bar -->
        <Grid Grid.Row="7" RowDefinitions="Auto,Auto" RowSpacing="4">
            <ProgressBar
                Grid.Row="0"
                Value="{x:Bind ViewModel.Progress, Mode=OneWay}"
                Maximum="100"
                Opacity="{x:Bind ViewModel.Progress, Mode=OneWay}"/>
            <TextBlock
                Grid.Row="1"
                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                Opacity="0.7"
                FontSize="12"/>
        </Grid>

    </Grid>
</Window>
