<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Archiver.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Archiver.App"
    xmlns:viewmodels="using:Archiver.App.ViewModels"
    Title="Archiver">

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto,Auto,Auto,Auto" Padding="16" RowSpacing="12">

        <!-- Row 0: Drop Zone -->
        <Border
            Grid.Row="0"
            Height="120"
            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
            BorderThickness="2"
            CornerRadius="8"
            AllowDrop="True"
            DragOver="DropZone_DragOver"
            Drop="DropZone_Drop"
            DoubleTapped="DropZone_DoubleTapped"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                <FontIcon Glyph="&#xE8B7;" FontSize="28" Opacity="0.6"/>
                <TextBlock
                    Text="Drop files or folders here, or double-click to browse files"
                    HorizontalAlignment="Center"
                    Opacity="0.6"/>
            </StackPanel>
        </Border>

        <!-- Row 1: Add Files / Add Folder Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <Button
                Content="Add files"
                Command="{x:Bind ViewModel.BrowseFilesCommand, Mode=OneWay}"/>
            <Button
                Content="Add folder"
                Command="{x:Bind ViewModel.BrowseFolderCommand, Mode=OneWay}"/>
        </StackPanel>

        <!-- Row 2: Selected Files List -->
        <ListView
            Grid.Row="2"
            ItemsSource="{x:Bind ViewModel.SelectedPaths, Mode=OneWay}"
            SelectionMode="None"
            MinHeight="80">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <TextBlock
                        Text="{x:Bind}"
                        TextTrimming="CharacterEllipsis"
                        ToolTipService.ToolTip="{x:Bind}">
                        <TextBlock.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Remove"
                                    Click="RemoveItem_Click"/>
                            </MenuFlyout>
                        </TextBlock.ContextFlyout>
                    </TextBlock>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Row 3: Destination Path -->
        <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto">
            <TextBlock
                Grid.Column="0"
                Text="Destination:"
                VerticalAlignment="Center"
                Margin="0,0,8,0"/>
            <TextBox
                Grid.Column="1"
                Text="{x:Bind ViewModel.DestinationPath, Mode=OneWay}"
                IsReadOnly="True"
                VerticalAlignment="Center"/>
            <Button
                Grid.Column="2"
                Content="..."
                Margin="8,0,0,0"
                Command="{x:Bind ViewModel.BrowseDestinationCommand, Mode=OneWay}"/>
        </Grid>

        <!-- Row 4: Action Buttons -->
        <Grid Grid.Row="4" ColumnDefinitions="*,*,Auto">

            <Button
                Grid.Column="0"
                Content="Archive"
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.ArchiveCommand, Mode=OneWay}"
                Style="{StaticResource AccentButtonStyle}"/>

            <Button
                Grid.Column="1"
                Content="Extract"
                Margin="8,0,0,0"
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.ExtractCommand, Mode=OneWay}"/>

            <Button
                Grid.Column="2"
                Content="Clear"
                Margin="8,0,0,0"
                Command="{x:Bind ViewModel.ClearCommand, Mode=OneWay}"/>
        </Grid>

        <!-- Row 5: Archive Name -->
        <Grid Grid.Row="5" ColumnDefinitions="Auto,*">
            <TextBlock
                Grid.Column="0"
                Text="Name:"
                VerticalAlignment="Center"
                Margin="0,0,8,0"/>
            <TextBox
                Grid.Column="1"
                Text="{x:Bind ViewModel.ArchiveName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                PlaceholderText="Auto (based on first file/folder name)"/>
        </Grid>

        <!-- Row 6: Post-Action Checkboxes -->
        <StackPanel Grid.Row="6" Spacing="4">
            <CheckBox
                Content="Open destination folder after completion"
                IsChecked="{x:Bind ViewModel.OpenDestinationFolder, Mode=TwoWay}"/>
            <CheckBox
                Content="Delete source files after archiving"
                IsChecked="{x:Bind ViewModel.DeleteSourceFiles, Mode=TwoWay}"/>
            <CheckBox
                Content="Delete archive after extraction"
                IsChecked="{x:Bind ViewModel.DeleteArchiveAfterExtraction, Mode=TwoWay}"/>
        </StackPanel>

        <!-- Row 7: Status Bar -->
        <Grid Grid.Row="7" RowDefinitions="Auto,Auto" RowSpacing="4">
            <ProgressBar
                Grid.Row="0"
                Value="{x:Bind ViewModel.Progress, Mode=OneWay}"
                Maximum="100"
                Opacity="{x:Bind ViewModel.Progress, Mode=OneWay}"/>
            <TextBlock
                Grid.Row="1"
                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                Opacity="0.7"
                FontSize="12"/>
        </Grid>

    </Grid>
</Window>
