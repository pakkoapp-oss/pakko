<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Archiver.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Archiver.App"
    xmlns:viewmodels="using:Archiver.App.ViewModels"
    xmlns:models="using:Archiver.App.Models"
    xmlns:tb="using:H.NotifyIcon"
    Title="Archiver">

    <Grid RowDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto" Padding="16" RowSpacing="12">

        <!-- Tray icon -->
        <tb:TaskbarIcon
            x:Name="TrayIcon"
            LeftClickCommand="{x:Bind TrayLeftClickCommand}"
            ToolTipText="Pakko"
            IconSource="Assets/Square44x44Logo.ico">
            <tb:TaskbarIcon.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem Text="Open Pakko" Command="{x:Bind TrayOpenCommand}"/>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem Text="About Pakko" Command="{x:Bind TrayAboutCommand}"/>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem Text="Exit" Command="{x:Bind TrayExitCommand}"/>
                </MenuFlyout>
            </tb:TaskbarIcon.ContextFlyout>
        </tb:TaskbarIcon>

        <!-- Row 0: Add Files / Add Folder / About Buttons -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,*,Auto" MinHeight="40">
            <Button
                Grid.Column="0"
                x:Uid="AddFilesButton"
                Command="{x:Bind ViewModel.BrowseFilesCommand, Mode=OneWay}"/>
            <Button
                Grid.Column="1"
                x:Uid="AddFolderButton"
                Margin="8,0,0,0"
                Command="{x:Bind ViewModel.BrowseFolderCommand, Mode=OneWay}"/>
            <Button
                Grid.Column="3"
                Content="About"
                HorizontalAlignment="Right"
                Command="{x:Bind TrayAboutCommand, Mode=OneWay}"/>
        </Grid>

        <!-- Row 1: File Table -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*">

            <!-- Header -->
            <Border
                Grid.Row="0"
                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*,80,100,140" Margin="12,0,12,0">
                    <Button Grid.Column="0" Content="Name"
                            Command="{x:Bind ViewModel.SortByCommand, Mode=OneWay}"
                            CommandParameter="Name"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0"
                            Padding="0,6,0,6" FontWeight="SemiBold"/>
                    <Button Grid.Column="1" Content="Type"
                            Command="{x:Bind ViewModel.SortByCommand, Mode=OneWay}"
                            CommandParameter="Type"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0"
                            Padding="0,6,0,6" FontWeight="SemiBold"/>
                    <Button Grid.Column="2" Content="Size"
                            Command="{x:Bind ViewModel.SortByCommand, Mode=OneWay}"
                            CommandParameter="Size"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0"
                            Padding="0,6,0,6" FontWeight="SemiBold"/>
                    <Button Grid.Column="3" Content="Modified"
                            Command="{x:Bind ViewModel.SortByCommand, Mode=OneWay}"
                            CommandParameter="Modified"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0"
                            Padding="0,6,0,6" FontWeight="SemiBold"/>
                </Grid>
            </Border>

            <!-- Body: ListView + empty-state hint overlay in the same cell -->
            <Grid Grid.Row="1">
                <ListView
                    ItemsSource="{x:Bind ViewModel.FileItems, Mode=OneWay}"
                    SelectionMode="None"
                    MinHeight="80"
                    AllowDrop="True"
                    DragOver="FileList_DragOver"
                    Drop="FileList_Drop">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="12,4,12,4"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:FileItem">
                            <Grid ColumnDefinitions="*,80,100,140">
                                <Grid.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Remove" Click="RemoveItem_Click"/>
                                    </MenuFlyout>
                                </Grid.ContextFlyout>
                                <TextBlock
                                    Grid.Column="0"
                                    Text="{x:Bind Name}"
                                    TextTrimming="CharacterEllipsis"
                                    ToolTipService.ToolTip="{x:Bind FullPath}"/>
                                <TextBlock
                                    Grid.Column="1"
                                    Text="{x:Bind Type}"
                                    TextTrimming="CharacterEllipsis"
                                    Opacity="0.7"/>
                                <TextBlock
                                    Grid.Column="2"
                                    Text="{x:Bind Size, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis"
                                    Opacity="0.7"/>
                                <TextBlock
                                    Grid.Column="3"
                                    Text="{x:Bind ModifiedDisplay}"
                                    TextTrimming="CharacterEllipsis"
                                    Opacity="0.7"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Empty-state hint overlay -->
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="4"
                    IsHitTestVisible="False"
                    Visibility="{x:Bind ViewModel.IsFileListEmptyVisibility, Mode=OneWay}">
                    <FontIcon Glyph="&#xE8B7;" FontSize="28" Opacity="0.6"/>
                    <TextBlock
                        x:Uid="DropZoneHint"
                        HorizontalAlignment="Center"
                        Opacity="0.6"/>
                </StackPanel>
            </Grid>

        </Grid>

        <!-- Row 2: Destination Path -->
        <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" MinHeight="40">
            <TextBlock
                x:Uid="DestinationLabel"
                Grid.Column="0"
                VerticalAlignment="Center"
                Margin="0,0,8,0"/>
            <TextBox
                Grid.Column="1"
                Text="{x:Bind ViewModel.DestinationPath, Mode=OneWay}"
                IsReadOnly="True"
                VerticalAlignment="Center"/>
            <Button
                Grid.Column="2"
                Content="..."
                Margin="8,0,0,0"
                Command="{x:Bind ViewModel.BrowseDestinationCommand, Mode=OneWay}"/>
        </Grid>

        <!-- Row 3: Action Buttons -->
        <Grid Grid.Row="3" ColumnDefinitions="*,*,Auto" MinHeight="40">

            <Button
                Grid.Column="0"
                Content="{x:Bind ViewModel.ArchiveButtonText, Mode=OneWay}"
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.ArchiveCommand, Mode=OneWay}"
                Style="{StaticResource AccentButtonStyle}"/>

            <Button
                Grid.Column="1"
                Content="{x:Bind ViewModel.ExtractButtonText, Mode=OneWay}"
                Margin="8,0,0,0"
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.ExtractCommand, Mode=OneWay}"/>

            <Button
                x:Uid="ClearButton"
                Grid.Column="2"
                Margin="8,0,0,0"
                Command="{x:Bind ViewModel.ClearCommand, Mode=OneWay}"/>
        </Grid>

        <!-- Row 4: Archive Options (Mode + Name) -->
        <StackPanel Grid.Row="4" Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="16" MinHeight="40">
                <TextBlock Text="Mode:" VerticalAlignment="Center" Width="46"/>
                <RadioButton
                    GroupName="ArchiveMode"
                    Content="One archive"
                    IsChecked="{x:Bind ViewModel.IsSingleArchive, Mode=TwoWay}"/>
                <RadioButton
                    GroupName="ArchiveMode"
                    Content="Separate archives"
                    IsChecked="{x:Bind ViewModel.IsSeparateArchives, Mode=TwoWay}"/>
            </StackPanel>
            <Grid ColumnDefinitions="Auto,*">
                <TextBlock
                    x:Uid="ArchiveNameLabel"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0"
                    Width="46"/>
                <TextBox
                    Grid.Column="1"
                    Text="{x:Bind ViewModel.ArchiveName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="Auto (based on first file/folder name)"
                    IsEnabled="{x:Bind ViewModel.IsArchiveNameEnabled, Mode=OneWay}"/>
            </Grid>
            <StackPanel Orientation="Horizontal" Spacing="8" MinHeight="40">
                <TextBlock x:Uid="CompressionLabel" VerticalAlignment="Center"/>
                <ComboBox MinHeight="32" SelectedIndex="{x:Bind ViewModel.CompressionLevelIndex, Mode=TwoWay}">
                    <ComboBoxItem Content="Fast"/>
                    <ComboBoxItem Content="Normal"/>
                    <ComboBoxItem Content="Best"/>
                    <ComboBoxItem Content="None"/>
                </ComboBox>
            </StackPanel>
        </StackPanel>

        <!-- Row 5: Shared Options + Post-Action Checkboxes -->
        <StackPanel Grid.Row="5" Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8" MinHeight="40">
                <TextBlock x:Uid="ConflictLabel" VerticalAlignment="Center"/>
                <ComboBox MinHeight="32" SelectedIndex="{x:Bind ViewModel.OnConflictIndex, Mode=TwoWay}">
                    <ComboBoxItem Content="Overwrite"/>
                    <ComboBoxItem Content="Skip"/>
                    <ComboBoxItem Content="Rename (add number)"/>
                </ComboBox>
            </StackPanel>
            <CheckBox
            x:Uid="OpenDestinationCheck"
            IsChecked="{x:Bind ViewModel.OpenDestinationFolder, Mode=TwoWay}"/>
            <CheckBox
            x:Uid="DeleteAfterOperationCheck"
            IsChecked="{x:Bind ViewModel.DeleteAfterOperation, Mode=TwoWay}"/>
        </StackPanel>

        <!-- Row 6: Status Bar -->
        <Grid Grid.Row="6" RowDefinitions="Auto,Auto" RowSpacing="4">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                <ProgressBar
                    Grid.Column="0"
                    Value="{x:Bind ViewModel.Progress, Mode=OneWay}"
                    Maximum="100"
                    IsIndeterminate="{x:Bind ViewModel.IsIndeterminate, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.IsOperationRunningVisibility, Mode=OneWay}"/>
                <Button
                    Grid.Column="1"
                    Content="✕ Cancel"
                    Margin="8,0,0,0"
                    Command="{x:Bind ViewModel.CancelCommand, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.IsOperationRunningVisibility, Mode=OneWay}"/>
            </Grid>
            <TextBlock
                Grid.Row="1"
                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                Opacity="0.7"
                FontSize="12"/>
        </Grid>
    </Grid>
</Window>
